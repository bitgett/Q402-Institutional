# ─── Q402 Relayer ────────────────────────────────────────────────────────────
# 이 키의 지갑이 각 체인에서 gas를 지불합니다
RELAYER_PRIVATE_KEY=your_private_key_here

# Q402PaymentImplementation contract addresses (optional — defaults in code)
AVAX_IMPLEMENTATION_CONTRACT=0x96a8C74d95A35D0c14Ec60364c78ba6De99E9A4c
BNB_IMPLEMENTATION_CONTRACT=0x6cF4aD62C208b6494a55a1494D497713ba013dFa
ETH_IMPLEMENTATION_CONTRACT=0x8E67a64989CFcb0C40556b13ea302709CCFD6AaD
XLAYER_IMPLEMENTATION_CONTRACT=0x8D854436ab0426F5BC6Cc70865C90576AD523E73
STABLE_IMPLEMENTATION_CONTRACT=0x2fb2B2D110b6c5664e701666B3741240242bf350
MANTLE_IMPLEMENTATION_CONTRACT=0xE5b90D564650bdcE7C2Bb4344F777f6582e05699
INJECTIVE_IMPLEMENTATION_CONTRACT=0xa9a7dcE76DEF2AC36057FeF0d8103dF10581d61e
MONAD_IMPLEMENTATION_CONTRACT=0xc5d4dFA6D2e545409C1abf86f336Dd43bb87621f
SCROLL_IMPLEMENTATION_CONTRACT=0x7635F32D893B64b5944CB8cbF2AC4cd3dA41B2f1
ARBITRUM_IMPLEMENTATION_CONTRACT=0x8D854436ab0426F5BC6Cc70865C90576AD523E73

# ─── Vercel KV (Upstash Redis) ───────────────────────────────────────────────
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_kv_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token
KV_URL=redis://default:your_password@your-kv-instance.upstash.io:6379
REDIS_URL=redis://default:your_password@your-kv-instance.upstash.io:6379

# ─── Admin ───────────────────────────────────────────────────────────────────
# Used by /api/keys/generate, /api/keys/topup, /api/gas-tank/withdraw, etc.
# MUST be cryptographically random (e.g. openssl rand -hex 32)
ADMIN_SECRET=replace_with_random_hex_32

# ─── Agentic Wallet keystore ─────────────────────────────────────────────────
# AES-256-GCM master key used to wrap per-user Agentic Wallet private keys
# stored in Vercel KV. Generate once; rotate via
# scripts/rotate-keystore-key.mjs (re-encrypts every record under the new
# key before swapping the env var).
#   openssl rand -hex 32
# Required for /api/wallet/agentic/* routes; if unset the routes return 503.
KEY_ENCRYPTION_KEY=replace_with_random_hex_32

# ─── Cron ────────────────────────────────────────────────────────────────────
# Vercel Cron bearer for /api/cron/gas-alert and /api/cron/usage-alert.
# Fail-closed: unset = all requests rejected.
CRON_SECRET=replace_with_random_hex_32

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# Secondary sink for CRITICAL ops alerts only (uncertain settlements, stuck
# crons, compliance-screen outages). If Telegram is down/misconfigured, these
# still reach you by email (Resend). No-op if unset.
OPS_ALERT_EMAIL=ops@quackai.ai

# ─── Email Alerts (Resend, v1.19) ────────────────────────────────────────────
# Used by /api/cron/usage-alert to send 20 % / 10 % TX-credit warnings.
# Without RESEND_API_KEY the cron counters stay at 0 and no email is sent
# (useful for local dev). RESEND_FROM_ADDRESS domain must be Resend-verified
# (DKIM/SPF/MX green) — otherwise Resend returns 403 at send time.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS=Q402 <alerts@quackai.ai>

# ─── Optional ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://q402.quackai.ai
# Per-chain RPC override. Every chain reads {CHAIN}_RPC_URL and falls back to a
# public default in code. Set these to a paid provider (Alchemy/QuickNode/dRPC)
# to swap off a degraded public endpoint without touching code — the public
# defaults rate-limit first under load. CHAIN_RPC_FALLBACKS in relayer.ts lists
# the secondary public endpoints used as in-code fallbacks.
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BNB_RPC_URL=https://bsc-dataseed1.binance.org/
ETH_RPC_URL=https://ethereum.publicnode.com
XLAYER_RPC_URL=https://rpc.xlayer.tech
STABLE_RPC_URL=https://rpc.stable.xyz
MANTLE_RPC_URL=https://rpc.mantle.xyz
INJECTIVE_RPC_URL=https://sentry.evm-rpc.injective.network/
MONAD_RPC_URL=https://rpc.monad.xyz
SCROLL_RPC_URL=https://rpc.scroll.io
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ─── Owner / paywall bypass list ─────────────────────────────────────────────
# Owner EOAs that bypass the dashboard paywall (comma-separated, addresses
# in any case — the parser lowercases). SERVER-ONLY (no NEXT_PUBLIC_ prefix)
# so the list never reaches the client bundle. Clients learn only their own
# isOwner boolean via authenticated /api/keys/provision.
# Read at request time → updates take effect on the next request after a
# Vercel env change (no rebuild needed; no restart needed in dev).
# Invalid entries are dropped with a console.warn at boot.
OWNER_WALLETS=0xowner1,0xowner2

# ─── Internal scripts (not used by the Next app) ─────────────────────────────
# scripts/transfer-sponsored*.mjs and scripts/check-balances.mjs read these.
# Only set them in the local env file you pass to those scripts; they have no
# effect on the running Next.js app.
Q402_FROM_ADDR=0xpayer
Q402_TO_ADDR=0xrecipient
Q402_PAYER=0xpayer
Q402_TEST_RECIPIENT=0xrecipient
