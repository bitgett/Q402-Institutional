# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — broad pattern. Catches `.env`, `.env.local`, `.env.preview`,
# `.env.production` (any of which can contain live KV / Resend / Google
# OAuth / relayer-key secrets pulled via `vercel env pull`). The
# committed `.env.example` is the only allowed env file.
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Runtime data — contains live API keys and subscription records; never commit
data/

# Standalone MCP server package — published separately to npm + github.com/bitgett/q402-mcp
mcp-server/
.pr-body.md

# Ambassador wallet automation (local-only, never push)
# Contains live BIP39 seed-derived private keys + master wallet PK + apiKeys.
scripts/.seed.env
scripts/.master.env
scripts/wallets.csv
scripts/ambassadors.csv
scripts/subscribe-state.json
scripts/balance-audit.json
seed.txt
# Ambassador automation scripts (separate project, not for product repo)
scripts/derive-from-seed.mjs
scripts/audit-balances.mjs
scripts/subscribe-daemon.mjs
scripts/enrich-row.mjs
